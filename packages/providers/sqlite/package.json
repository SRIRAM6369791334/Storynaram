{
    "name": "@storynaram/sqlite-provider",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "sideEffects": false,
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "tsc",
        "clean": "rimraf dist",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "bench": "vitest run --include '**/*.bench.ts'",
        "lint": "eslint src/"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@storynaram/core": "workspace:^",
        "@storynaram/runtime": "workspace:^",
        "@storynaram/logger": "workspace:^",
        "better-sqlite3": "^11.0.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "uuid": "^14.0.1"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.0.0",
        "@types/better-sqlite3": "^7.6.0",
        "@types/uuid": "^11.0.0",
        "vitest": "^3.0.0"
    }
}
