{
  "name": "@storynaram/testing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "vitest": "^2.1.0",
    "@storynaram/core": "workspace:*",
    "@storynaram/common": "workspace:*",
    "@storynaram/logger": "workspace:*",
    "@storynaram/config": "workspace:*",
    "@storynaram/events": "workspace:*",
    "@storynaram/telemetry": "workspace:*"
  }
}
