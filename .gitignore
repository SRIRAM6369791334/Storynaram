# Storynaram .gitignore

# =====================
# Operating System Files
# =====================
Thumbs.db
.DS_Store
Desktop.ini
*.swp
*.swo
*~
~$*

# =====================
# IDE and Editor Files
# =====================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.code-workspace
.project
.classpath
.settings/
*.iml

# =====================
# Python
# =====================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# =====================
# Node
# =====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =====================
# Logs
# =====================
*.log
/logs/*.log
/logs/**/*.log

# =====================
# Secrets and Credentials
# =====================
*.key
*.pem
*.cert
*.secret
.env
.env.local
.env.*.local
secrets/
credentials/
api_keys/

# =====================
# Backup and Archive
# =====================
/backups/
/archive/

# =====================
# Export Outputs
# =====================
/exports/*.epub
/exports/*.mobi
/exports/*.pdf
/exports/*.docx

# =====================
# Large Generated Files
# =====================
*.generated.*
/tmp/
/temp/

# =====================
# AI Cache and Temp
# =====================
.ai_cache/
.ai_temp/

# =====================
# Version Control Exclusions
# =====================
# Keep config JSONs but ignore local overrides
/config/local.*.json

# =====================
# Windows specific
# =====================
*.lnk
