        "type": "string"
      }
    },
    "roleCheck": {
      "type": "object",
      "additionalProperties": true
    },
    "ownerCheck": {
      "type": "object",
      "additionalProperties": true
    },
    "groupCheck": {
      "type": "object",
      "additionalProperties": true
    },
    "inheritanceCheck": {
      "type": "object",
      "additionalProperties": true
    },
    "restrictionCheck": {
      "type": "object",
      "additionalProperties": true
    }
  }
