{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/core/BaseRelationship.schema.json",
  "title": "BaseRelationship",
  "description": "Relationship block with full cardinality and type support",
  "type": "object",
  "properties": {
    "relationships": {
      "type": "array",
      "description": "All typed relationships from this entity to others",
      "items": {
        "type": "object",
        "required": ["targetId", "targetType", "type"],
        "properties": {
          "targetId": { "type": "string" },
          "targetType": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["oneToOne", "oneToMany", "manyToMany", "composition", "aggregation", "association", "dependency", "inheritance"]
          },
          "role": { "type": "string", "description": "Semantic role label" },
          "inverseRole": { "type": "string", "description": "Inverse role on the target side" },
          "cardinality": {
            "type": "object",
            "properties": {
              "min": { "type": "integer", "minimum": 0, "default": 0 },
              "max": { "type": "integer", "minimum": 1, "default": 1 }
            }
          },
          "strength": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "graphMappings": {
      "type": "object",
      "description": "Mappings for graph database edge generation",
      "properties": {
        "edgeLabels": { "type": "array", "items": { "type": "string" } },
        "nodeLabels": { "type": "array", "items": { "type": "string" } },
        "properties": { "type": "object" }
      }
    }
  }
}
