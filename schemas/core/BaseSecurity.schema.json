{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/core/BaseSecurity.schema.json",
  "title": "BaseSecurity",
  "description": "Security configuration block — encryption, redaction, audit logging, data classification, and access policies",
  "type": "object",
  "properties": {
    "classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted", "secret"],
      "description": "Data classification level"
    },
    "encryption": {
      "type": "object",
      "description": "Field-level encryption settings",
      "properties": {
        "atRest": { "type": "boolean", "default": false },
        "inTransit": { "type": "boolean", "default": true },
        "encryptedFields": {
          "type": "array",
          "description": "Fields that must be encrypted at rest",
          "items": { "type": "string" }
        }
      }
    },
    "redaction": {
      "type": "array",
      "description": "Fields with redaction/obfuscation rules",
      "items": {
        "type": "object",
        "properties": {
          "field": { "type": "string" },
          "method": { "type": "string", "enum": ["mask", "truncate", "hash", "remove"] },
          "condition": { "type": "string", "description": "Role or context requiring redaction" }
        }
      }
    },
    "auditLogging": {
      "type": "object",
      "description": "Security audit logging configuration",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "retentionDays": { "type": "integer", "default": 365 }
      }
    },
    "accessPolicy": {
      "type": "object",
      "description": "Access policy identifiers",
      "properties": {
        "policyId": { "type": "string" },
        "attributes": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    }
  }
}
