{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/domain/TimelineEvent.schema.json",
  "title": "TimelineEvent",
  "description": "TimelineEvent domain schema — inherits BaseEntity via allOf, adds timeline-event-specific fields under entity block",
  "type": "object",
  "allOf": [{ "$ref": "../core/BaseEntity.schema.json" }],
  "properties": {
    "entity": {
      "type": "object",
      "description": "TimelineEvent-specific fields",
      "required": ["date", "timelineId"],
      "properties": {
        "timelineId": { "type": "string" },
        "date": {
          "type": "object",
          "properties": {
            "year": { "type": "string" },
            "month": { "type": "string" },
            "day": { "type": "string" },
            "time": { "type": "string" },
            "era": { "type": "string" },
            "display": { "type": "string" }
          }
        },
        "type": { "type": "string", "enum": ["major", "minor", "catalyst", "climax", "resolution", "background"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" } },
        "causes": { "type": "array", "items": { "type": "string" } },
        "consequences": { "type": "array", "items": { "type": "string" } },
        "significance": { "type": "integer", "minimum": 0, "maximum": 100 },
        "relatedEvents": { "type": "array", "items": { "type": "string" } },
        "sources": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "unevaluatedProperties": false
}
