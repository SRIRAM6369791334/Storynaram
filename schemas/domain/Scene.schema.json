{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/domain/Scene.schema.json",
  "title": "Scene",
  "description": "Scene domain schema — inherits BaseEntity via allOf, adds scene-specific fields under entity block",
  "type": "object",
  "allOf": [{ "$ref": "../core/BaseEntity.schema.json" }],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Scene-specific fields",
      "required": ["location", "timelinePosition"],
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "chapterId": { "type": "string" },
        "bookId": { "type": "string" },
        "characters": { "type": "array", "items": { "type": "string" } },
        "pointOfView": { "type": "string" },
        "location": { "type": "string" },
        "timelinePosition": {
          "type": "object",
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" },
            "order": { "type": "integer" }
          }
        },
        "dialogue": { "type": "array", "items": { "type": "string" } },
        "mood": { "type": "string" },
        "tone": { "type": "string" },
        "purpose": { "type": "string" },
        "conflict": { "type": "string" },
        "plotPoints": { "type": "array", "items": { "type": "string" } },
        "wordCount": { "type": "integer", "minimum": 0 },
        "content": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  },
  "unevaluatedProperties": false
}
