{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/domain/Country.schema.json",
  "title": "Country",
  "description": "Country domain schema — inherits BaseEntity via allOf, adds country-specific fields under entity block",
  "type": "object",
  "allOf": [{ "$ref": "../core/BaseEntity.schema.json" }],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Country-specific fields",
      "required": ["worldId"],
      "properties": {
        "worldId": { "type": "string" },
        "capital": { "type": "string" },
        "government": { "type": "string" },
        "ruler": { "type": "string" },
        "cities": { "type": "array", "items": { "type": "string" } },
        "regions": { "type": "array", "items": { "type": "string" } },
        "population": { "type": "integer", "minimum": 0 },
        "area": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "currency": { "type": "string" },
        "exports": { "type": "array", "items": { "type": "string" } },
        "imports": { "type": "array", "items": { "type": "string" } },
        "military": { "type": "string" },
        "allies": { "type": "array", "items": { "type": "string" } },
        "enemies": { "type": "array", "items": { "type": "string" } },
        "history": { "type": "string" }
      }
    }
  },
  "unevaluatedProperties": false
}
