{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/domain/Family.schema.json",
  "title": "Family",
  "description": "Family domain schema — inherits BaseEntity via allOf, adds family-specific fields under entity block",
  "type": "object",
  "allOf": [{ "$ref": "../core/BaseEntity.schema.json" }],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Family-specific fields",
      "properties": {
        "worldId": { "type": "string" },
        "type": { "type": "string", "enum": ["noble", "royal", "merchant", "artisan", "peasant", "criminal", "magical", "other"] },
        "head": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "ancestors": { "type": "array", "items": { "type": "string" } },
        "familyTree": { "type": "string" },
        "motto": { "type": "string" },
        "sigil": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "titles": { "type": "array", "items": { "type": "string" } },
        "holdings": { "type": "array", "items": { "type": "string" } },
        "alliances": { "type": "array", "items": { "type": "string" } },
        "rivalries": { "type": "array", "items": { "type": "string" } },
        "history": { "type": "string" }
      }
    }
  },
  "unevaluatedProperties": false
}
