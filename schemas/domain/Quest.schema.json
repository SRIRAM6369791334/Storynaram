{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/domain/Quest.schema.json",
  "title": "Quest",
  "description": "Quest domain schema — inherits BaseEntity via allOf, adds quest-specific fields under entity block",
  "type": "object",
  "allOf": [{ "$ref": "../core/BaseEntity.schema.json" }],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Quest-specific fields",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["main", "side", "personal", "faction", "world", "character-arc", "episodic"] },
        "bookId": { "type": "string" },
        "giver": { "type": "string" },
        "objectives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "completed": { "type": "boolean", "default": false },
              "order": { "type": "integer" }
            }
          }
        },
        "participants": { "type": "array", "items": { "type": "string" } },
        "rewards": { "type": "array", "items": { "type": "string" } },
        "difficulty": { "type": "string", "enum": ["trivial", "easy", "medium", "hard", "deadly", "impossible"] },
        "stages": { "type": "array", "items": { "type": "string" } },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "failConditions": { "type": "array", "items": { "type": "string" } },
        "relatedQuests": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "unevaluatedProperties": false
}
