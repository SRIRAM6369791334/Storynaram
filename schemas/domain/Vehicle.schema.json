{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/domain/Vehicle.schema.json",
  "title": "Vehicle",
  "description": "Vehicle domain schema — inherits BaseEntity via allOf, adds vehicle-specific fields under entity block",
  "type": "object",
  "allOf": [{ "$ref": "../core/BaseEntity.schema.json" }],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Vehicle-specific fields",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["ship", "boat", "carriage", "wagon", "airship", "flying", "submersible", "land", "space", "magical", "other"] },
        "worldId": { "type": "string" },
        "owner": { "type": "string" },
        "crew": { "type": "array", "items": { "type": "string" } },
        "capacity": { "type": "integer", "minimum": 0 },
        "speed": { "type": "string" },
        "weapons": { "type": "array", "items": { "type": "string" } },
        "defenses": { "type": "array", "items": { "type": "string" } },
        "propulsion": { "type": "string" },
        "size": { "type": "string" },
        "material": { "type": "string" },
        "condition": { "type": "integer", "minimum": 0, "maximum": 100 },
        "history": { "type": "string" }
      }
    }
  },
  "unevaluatedProperties": false
}
