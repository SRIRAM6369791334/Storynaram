{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/domain/Kingdom.schema.json",
  "title": "Kingdom",
  "description": "Kingdom domain schema — inherits BaseEntity via allOf, adds kingdom-specific fields under entity block",
  "type": "object",
  "allOf": [{ "$ref": "../core/BaseEntity.schema.json" }],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Kingdom-specific fields",
      "required": ["worldId"],
      "properties": {
        "worldId": { "type": "string" },
        "countryId": { "type": "string" },
        "capital": { "type": "string" },
        "monarch": { "type": "string" },
        "government": { "type": "string" },
        "succession": { "type": "string", "enum": ["primogeniture", "elective", "merit", "conquest", "appointed", "other"] },
        "royalHouse": { "type": "string" },
        "cities": { "type": "array", "items": { "type": "string" } },
        "territories": { "type": "array", "items": { "type": "string" } },
        "population": { "type": "integer", "minimum": 0 },
        "founded": { "type": "string" },
        "fell": { "type": "string" },
        "motto": { "type": "string" },
        "sigil": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "unevaluatedProperties": false
}
