{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storynaram.dev/schemas/workflow/WorkflowCondition.schema.json",
  "title": "WorkflowCondition",
  "description": "Condition definitions for workflow transitions and triggers",
  "type": "object",
  "$defs": {
    "ConditionDefinition": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["field", "status", "relationship", "time", "permission", "ai", "custom"]
        },
        "expression": { "type": "string" },
        "field": { "type": "string" },
        "operator": {
          "type": "string",
          "enum": ["equals", "not-equals", "greater-than", "less-than", "in", "not-in", "exists", "not-exists", "matches", "custom"]
        },
        "value": {},
        "failMessage": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"]
        }
      }
    }
  },
  "properties": {
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/ConditionDefinition" }
    },
    "evaluationMode": {
      "type": "string",
      "enum": ["all", "any", "sequence"],
      "default": "all"
    }
  },
  "unevaluatedProperties": false
}
