{
  "$id": "https://storynaram.dev/schemas/workflow/WorkflowMetrics.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "unevaluatedProperties": false,
  "$defs": {
    "CounterFlags": {
      type: "object",
      properties: {
        transitions: { type: "boolean", default: true },
        retries: { type: "boolean", default: true },
        failures: { type: "boolean", default: true },
        approvals: { type: "boolean", default: true },
        rejections: { type: "boolean", default: true },
        timeouts: { type: "boolean", default: true }
      },
      unevaluatedProperties: false
    },
    "HistogramFlags": {
      type: "object",
      properties: {
        duration: { type: "boolean", default: true },
        approvalTime: { type: "boolean", default: false },
        aiLatency: { type: "boolean", default: false },
        queueWaitTime: { type: "boolean", default: false },
        actionExecutionTime: { type: "boolean", default: true }
      },
      unevaluatedProperties: false
    },
    "GaugeFlags": {
      type: "object",
      properties: {
        activeWorkflows: { type: "boolean", default: true },
        queuedTasks: { type: "boolean", default: true },
        concurrentExecutions: { type: "boolean", default: true },
        successRate: { type: "boolean", default: true }
      },
      unevaluatedProperties: false
    },
    "CustomMetric": {
      type: "object",
      properties: {
        name: { type: "string" },
        type: { type: "string", enum: ["counter", "histogram", "gauge"] },
        description: { type: "string" },
        tags: {
          type: "array",
          items: { type: "string" }
        }
      },
      unevaluatedProperties: false
    },
    "CustomConfig": {
      type: "object",
      properties: {
        labels: {
          type: "array",
          items: { type: "string" }
        },
        metrics: {
          type: "array",
          items: { "$ref": "#/$defs/CustomMetric" }
        }
      },
      unevaluatedProperties: false
    },
    "ExportConfig": {
      type: "object",
      properties: {
        enabled: { type: "boolean", default: false },
        provider: { type: "string", enum: ["prometheus", "datadog", "grafana", "cloudwatch", "custom"] },
        endpoint: { type: "string" },
        interval: { type: "integer", description: "Export interval in seconds" }
      },
      unevaluatedProperties: false
    }
  },
  "properties": {
    "enabled": { type: "boolean", default: true },
    "counters": { "$ref": "#/$defs/CounterFlags" },
    "histograms": { "$ref": "#/$defs/HistogramFlags" },
    "gauges": { "$ref": "#/$defs/GaugeFlags" },
    "custom": { "$ref": "#/$defs/CustomConfig" },
    "export": { "$ref": "#/$defs/ExportConfig" }
  }
}
