{
  "$id": "https://storynaram.dev/schemas/workflow/WorkflowAction.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "unevaluatedProperties": false,
  "$defs": {
    "ActionDefinition": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["system", "notification", "ai", "validation", "export", "import", "transform", "webhook", "plugin", "custom"]
        },
        "name": { "type": "string" },
        "config": {
          "type": "object",
          "additionalProperties": true
        },
        "order": { "type": "integer" },
        "async": { "type": "boolean", "default": false },
        "timeout": { "type": "integer" },
        "onFailure": {
          "type": "string",
          "enum": ["abort", "skip", "retry", "continue"]
        }
      }
    }
  },
  "properties": {
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/ActionDefinition" }
    }
  }
}
