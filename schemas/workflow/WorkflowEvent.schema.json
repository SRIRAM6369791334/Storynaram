{
  "$id": "https://storynaram.dev/schemas/workflow/WorkflowEvent.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "unevaluatedProperties": false,
  "$defs": {
    "EventSchema": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "properties": {
          "type": "object",
          "additionalProperties": true
        },
        "required": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "RoutingConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["direct", "fanout", "topic", "queue"]
        },
        "consumers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "priority": { "type": "integer" }
      }
    },
    "EventDefinition": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "entityCreated",
            "entityUpdated",
            "entityDeleted",
            "workflowStarted",
            "workflowCompleted",
            "approvalGranted",
            "approvalRejected",
            "aiFinished",
            "exportCompleted",
            "pluginExecuted"
          ]
        },
        "producer": { "type": "string" },
        "schema": { "$ref": "#/$defs/EventSchema" },
        "routing": { "$ref": "#/$defs/RoutingConfig" }
      }
    }
  },
  "properties": {
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/EventDefinition" }
    }
  }
}
