{
  "$id": "https://storynaram.dev/schemas/workflow/WorkflowSchedule.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "unevaluatedProperties": false,
  "$defs": {
    "Constraint": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["day-of-week", "day-of-month", "time-range", "holiday"]
        },
        "values": {
          "type": "array",
          "items": {}
        }
      }
    }
  },
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "cron": {
      "type": "string",
      "description": "Cron expression for scheduling"
    },
    "timezone": {
      "type": "string",
      "default": "UTC"
    },
    "startDate": {
      "type": "string",
      "format": "date-time"
    },
    "endDate": {
      "type": "string",
      "format": "date-time"
    },
    "maxExecutions": {
      "type": "integer",
      "minimum": 0,
      "description": "0 means unlimited"
    },
    "skipHolidays": {
      "type": "boolean",
      "default": false
    },
    "constraints": {
      "type": "array",
      "items": { "$ref": "#/$defs/Constraint" }
    }
  }
}
