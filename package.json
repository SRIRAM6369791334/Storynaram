{
  "name": "storynaram",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.0.0", "pnpm": ">=9.0.0" },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @storynaram/api dev",
    "build": "pnpm -r build",
    "build:affected": "pnpm --filter \"...[origin/main]\" build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check \"**/*.ts\"",
    "format:fix": "prettier --write \"**/*.ts\"",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @storynaram/api test:e2e",
    "clean": "pnpm -r clean",
    "reset": "pnpm clean && rimraf node_modules && pnpm install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.ts": ["eslint --fix", "prettier --write"]
  }
}
