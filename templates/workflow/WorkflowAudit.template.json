{
  "template": "WorkflowAudit",
  "version": "1.0.0",
  "description": "Audit trail configuration — immutable event log with retention, export, and integrity verification for compliance",
  "type": "object",
  "properties": {
    "enabled": { "type": "boolean", "default": true },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "action": { "type": "string" },
          "actor": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "details": { "type": "object" },
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string" },
                "oldValue": {},
                "newValue": {}
              }
            }
          }
        }
      }
    },
    "retention": {
      "type": "object",
      "properties": {
        "duration": { "type": "integer", "description": "Retention duration in seconds" },
        "archiveAfter": { "type": "integer", "description": "Archive after duration in seconds" },
        "storage": { "type": "string", "enum": ["database", "file", "object-store", "cold-storage"] }
      }
    },
    "export": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "format": { "type": "string", "enum": ["json", "csv", "parquet"] },
        "schedule": { "type": "string", "description": "Cron for scheduled export" },
        "destination": { "type": "string" }
      }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "hashAlgorithm": { "type": "string", "default": "sha256" },
        "signingEnabled": { "type": "boolean", "default": false },
        "verifyOnRead": { "type": "boolean", "default": true }
      }
    }
  }
}
