{
  "template": "WorkflowRollback",
  "version": "1.0.0",
  "description": "Rollback strategy definition — checkpoint-based and compensating rollback with undo actions, data restore, and notifications",
  "type": "object",
  "properties": {
    "enabled": { "type": "boolean", "default": false },
    "rollbackTo": { "type": "string", "description": "Checkpoint ID to roll back to" },
    "strategy": {
      "type": "string",
      "enum": ["sequential", "snapshot", "compensating"]
    },
    "undoActions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "actionId": { "type": "string" },
          "type": { "type": "string" },
          "order": { "type": "integer" },
          "compensatingAction": { "type": "string" },
          "params": { "type": "object" }
        }
      }
    },
    "dataRestore": {
      "type": "object",
      "properties": {
        "restoreEntities": { "type": "boolean", "default": true },
        "restoreState": { "type": "boolean", "default": true },
        "excludeFields": { "type": "array", "items": { "type": "string" } },
        "backupLocation": { "type": "string" }
      }
    },
    "notification": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "channels": { "type": "array", "items": { "type": "string" } },
        "message": { "type": "string" }
      }
    }
  }
}
