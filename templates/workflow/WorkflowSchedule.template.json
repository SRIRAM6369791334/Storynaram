{
  "template": "WorkflowSchedule",
  "version": "1.0.0",
  "description": "Scheduling configuration — cron-based execution with timezone, date constraints, holiday skipping, and execution limits",
  "type": "object",
  "properties": {
    "enabled": { "type": "boolean", "default": false },
    "cron": { "type": "string", "description": "Cron expression for scheduling" },
    "timezone": { "type": "string", "default": "UTC" },
    "startDate": { "type": "string", "format": "date-time" },
    "endDate": { "type": "string", "format": "date-time" },
    "maxExecutions": { "type": "integer", "minimum": 0, "description": "0 means unlimited" },
    "skipHolidays": { "type": "boolean", "default": false },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["day-of-week", "day-of-month", "time-range", "holiday"] },
          "values": { "type": "array", "items": {} }
        }
      }
    }
  }
}
