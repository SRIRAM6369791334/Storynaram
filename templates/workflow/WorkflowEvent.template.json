{
  "template": "WorkflowEvent",
  "version": "1.0.0",
  "description": "Event definitions — typed domain events with producer/consumer metadata, schema, and routing configuration",
  "type": "object",
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["entityCreated", "entityUpdated", "entityDeleted", "workflowStarted", "workflowCompleted", "approvalGranted", "approvalRejected", "aiFinished", "exportCompleted", "pluginExecuted"]
          },
          "producer": { "type": "string", "description": "Component that produces this event" },
          "schema": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "properties": { "type": "object" },
              "required": { "type": "array", "items": { "type": "string" } }
            }
          },
          "routing": {
            "type": "object",
            "properties": {
              "mode": { "type": "string", "enum": ["direct", "fanout", "topic", "queue"] },
              "consumers": { "type": "array", "items": { "type": "string" } },
              "priority": { "type": "integer" }
            }
          }
        },
        "required": ["id", "type"]
      }
    }
  }
}
