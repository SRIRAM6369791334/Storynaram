{
  "template": "AISummary",
  "version": "1.0.0",
  "description": "Summary generation block — configuration for auto-summarization of entities, contexts, and conversations",
  "type": "object",
  "properties": {
    "enabled": { "type": "boolean", "default": false },
    "strategy": {
      "type": "string",
      "enum": ["extractive", "abstractive", "hybrid"],
      "default": "abstractive"
    },
    "maxLength": { "type": "integer", "minimum": 50, "maximum": 4096 },
    "targetFields": { "type": "array", "items": { "type": "string" } },
    "regenerateOnUpdate": { "type": "boolean", "default": true },
    "summaries": {
      "type": "array",
      "description": "Generated summaries with versions",
      "items": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "summary": { "type": "string" },
          "model": { "type": "string" },
          "generatedAt": { "type": "string", "format": "date-time" },
          "tokens": { "type": "integer" }
        }
      }
    }
  }
}
