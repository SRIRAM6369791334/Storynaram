{
  "template": "AIRetrieval",
  "version": "1.0.0",
  "description": "Retrieval configuration block — keyword, semantic, hybrid, graph, timeline, relationship, canon, and memory retrieval",
  "type": "object",
  "properties": {
    "keyword": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "maxResults": { "type": "integer", "default": 10 }
      }
    },
    "semantic": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "model": { "type": "string" },
        "minScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "maxResults": { "type": "integer", "default": 5 }
      }
    },
    "hybrid": {
      "type": "object",
      "properties": {
        "fullTextWeight": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.4 },
        "semanticWeight": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.6 }
      }
    },
    "graph": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "traversalDepth": { "type": "integer", "default": 2 },
        "edgeTypes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "timeline": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "rangeStart": { "type": "string" },
        "rangeEnd": { "type": "string" }
      }
    },
    "relationship": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "maxHops": { "type": "integer", "default": 1 }
      }
    },
    "canon": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "strictMode": { "type": "boolean", "default": false }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "shortTerm": { "type": "boolean", "default": true },
        "longTerm": { "type": "boolean", "default": true },
        "maxMemoryItems": { "type": "integer", "default": 20 }
      }
    }
  }
}
