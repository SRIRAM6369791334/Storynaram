{
  "template": "BaseAudit",
  "version": "1.0.0",
  "description": "Provenance and accountability block — tracks who did what and when",
  "type": "object",
  "required": ["createdBy", "createdAt", "updatedBy", "updatedAt"],
  "properties": {
    "createdBy": {
      "type": "string",
      "description": "User/system that created the entity (user_id or system_id)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp"
    },
    "updatedBy": {
      "type": "string",
      "description": "Last user/system to modify the entity"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last-modification timestamp"
    },
    "approvedBy": {
      "type": "string",
      "description": "User/system that approved/published the entity"
    },
    "approvedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 approval timestamp"
    },
    "reviewedBy": {
      "type": "string",
      "description": "Last reviewer user/system"
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 review timestamp"
    },
    "lockedBy": {
      "type": "string",
      "description": "User/system that currently holds a lock on the entity"
    },
    "lockedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 lock timestamp"
    },
    "revision": {
      "type": "string",
      "description": "Current revision identifier (UUID or hash)"
    },
    "revisionNotes": {
      "type": "array",
      "description": "Annotated revision history",
      "items": {
        "type": "object",
        "properties": {
          "revision": { "type": "string" },
          "author": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "comment": { "type": "string" }
        }
      }
    }
  },
  "inheritanceRules": {
    "extensible": true,
    "overrideable": ["approvedBy", "approvedAt", "reviewedBy", "reviewedAt", "lockedBy", "lockedAt", "revisionNotes"],
    "final": ["createdBy", "createdAt", "updatedBy", "updatedAt", "revision"]
  }
}
