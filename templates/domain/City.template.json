{
  "template": "City",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseOwnership", "BaseReference", "BaseRelationship", "BaseTag", "BaseVisibility", "BaseLocalization", "BaseAttachment", "BaseValidation", "BaseAI", "BaseSearch", "BaseHistory", "BaseExtension"],
  "entityType": "city",
  "description": "Reusable city domain template. Defines a city, town, or settlement.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "City-specific fields",
      "required": ["worldId"],
      "properties": {
        "worldId": { "type": "string" },
        "countryId": { "type": "string" },
        "kingdomId": { "type": "string" },
        "type": { "type": "string", "enum": ["capital", "city", "town", "village", "hamlet", "fortress", "port", "trade-post", "religious", "academic"] },
        "population": { "type": "integer", "minimum": 0 },
        "area": { "type": "string" },
        "districts": { "type": "array", "items": { "type": "string" } },
        "notableLocations": { "type": "array", "items": { "type": "string" } },
        "governance": { "type": "string" },
        "ruler": { "type": "string" },
        "economy": { "type": "string" },
        "defenses": { "type": "string" },
        "demographics": { "type": "object" },
        "founded": { "type": "string" },
        "notableEvents": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
