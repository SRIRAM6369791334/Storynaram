{
  "template": "Book",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseLifecycle", "BaseOwnership", "BaseReference", "BaseRelationship", "BaseTag", "BaseVisibility", "BaseLocalization", "BaseAttachment", "BaseValidation", "BaseAI", "BaseSearch", "BaseHistory", "BaseExtension"],
  "entityType": "book",
  "description": "Reusable book/volume domain template. Defines structure for any book, novel, or volume.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Book-specific fields",
      "properties": {
        "series": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "position": { "type": "integer", "minimum": 1 },
            "totalBooks": { "type": "integer", "minimum": 1 }
          }
        },
        "structure": {
          "type": "object",
          "properties": {
            "parts": { "type": "array", "items": { "type": "string" } },
            "chapters": { "type": "array", "items": { "type": "string" } },
            "prologue": { "type": "boolean", "default": false },
            "epilogue": { "type": "boolean", "default": false },
            "interludes": { "type": "array", "items": { "type": "string" } },
            "appendixes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "wordCount": { "type": "integer", "minimum": 0 },
        "pageCount": { "type": "integer", "minimum": 0 },
        "genre": { "type": "array", "items": { "type": "string" } },
        "themes": { "type": "array", "items": { "type": "string" } },
        "pointOfView": { "type": "string", "enum": ["first-person", "second-person", "third-person-limited", "third-person-omniscient", "multiple"] },
        "tense": { "type": "string", "enum": ["past", "present", "future", "mixed"] },
        "narrativeStyle": { "type": "string", "enum": ["linear", "non-linear", "epistolary", "frame", "stream-of-consciousness", "multipov"] },
        "setting": {
          "type": "object",
          "properties": {
            "world": { "type": "string" },
            "timePeriod": { "type": "string" },
            "duration": { "type": "string" }
          }
        },
        "outline": { "type": "string" },
        "canonStatus": { "type": "string", "enum": ["primary", "side", "alternate", "deleted"] }
      }
    }
  }
}
