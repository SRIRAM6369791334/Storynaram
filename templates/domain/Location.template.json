{
  "template": "Location",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseOwnership", "BaseReference", "BaseRelationship", "BaseTag", "BaseVisibility", "BaseLocalization", "BaseAttachment", "BaseValidation", "BaseAI", "BaseSearch", "BaseHistory", "BaseExtension"],
  "entityType": "location",
  "description": "Reusable location domain template. Defines a place or point of interest.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Location-specific fields",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["planet", "continent", "country", "kingdom", "city", "town", "village", "region", "landmark", "building", "room", "natural", "ruin", "dungeon", "other"] },
        "worldId": { "type": "string" },
        "parentLocation": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "elevation": { "type": "number" },
            "mapReference": { "type": "string" }
          }
        },
        "climate": { "type": "string" },
        "terrain": { "type": "string" },
        "population": { "type": "integer", "minimum": 0 },
        "notableFeatures": { "type": "array", "items": { "type": "string" } },
        "controlledBy": { "type": "string" },
        "inhabitants": { "type": "array", "items": { "type": "string" } },
        "landmarks": { "type": "array", "items": { "type": "string" } },
        "connections": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
