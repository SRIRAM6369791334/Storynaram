{
  "template": "Chapter",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseOwnership", "BaseReference", "BaseRelationship", "BaseVisibility", "BaseAttachment", "BaseValidation", "BaseAI", "BaseHistory", "BaseExtension"],
  "entityType": "chapter",
  "description": "Reusable chapter domain template. Defines structure for any chapter within a book or part.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Chapter-specific fields",
      "required": ["bookId", "number"],
      "properties": {
        "bookId": { "type": "string" },
        "number": { "type": "integer", "minimum": 1 },
        "partId": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "scenes": { "type": "array", "items": { "type": "string" } },
        "wordCount": { "type": "integer", "minimum": 0 },
        "pointOfView": { "type": "string" },
        "timelineStart": { "type": "string" },
        "timelineEnd": { "type": "string" },
        "locations": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
