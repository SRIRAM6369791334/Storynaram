{
  "template": "Item",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseOwnership", "BaseReference", "BaseRelationship", "BaseTag", "BaseVisibility", "BaseValidation", "BaseAI", "BaseSearch", "BaseHistory", "BaseExtension"],
  "entityType": "item",
  "description": "Reusable item domain template. Defines any object, possession, or thing.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Item-specific fields",
      "required": ["category"],
      "properties": {
        "category": { "type": "string", "enum": ["weapon", "armor", "artifact", "tool", "consumable", "clothing", "jewelry", "book", "key", "food", "material", "currency", "miscellaneous"] },
        "subcategory": { "type": "string" },
        "material": { "type": "string" },
        "weight": { "type": "string" },
        "dimensions": { "type": "string" },
        "value": { "type": "object", "properties": { "currency": { "type": "string" }, "amount": { "type": "number", "minimum": 0 } } },
        "condition": { "type": "string" },
        "durability": { "type": "integer", "minimum": 0, "maximum": 100 },
        "magical": { "type": "boolean", "default": false },
        "magicalProperties": { "type": "array", "items": { "type": "string" } },
        "owner": { "type": "string" },
        "location": { "type": "string" },
        "history": { "type": "string" },
        "crafting": { "type": "object", "properties": { "creator": { "type": "string" }, "materials": { "type": "array", "items": { "type": "string" } }, "date": { "type": "string" } } }
      }
    }
  }
}
