{
  "template": "Species",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseReference", "BaseRelationship", "BaseTag", "BaseVisibility", "BaseLocalization", "BaseValidation", "BaseAI", "BaseSearch", "BaseExtension"],
  "entityType": "species",
  "description": "Reusable species domain template. Defines a biological species or sentient race.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Species-specific fields",
      "properties": {
        "worldId": { "type": "string" },
        "type": { "type": "string", "enum": ["humanoid", "beast", "avian", "aquatic", "reptilian", "insectoid", "plant", "elemental", "celestial", "infernal", "undead", "construct", "other"] },
        "classification": { "type": "string", "enum": ["sentient", "semi-sentient", "non-sentient", "magical", "divine"] },
        "lifespan": { "type": "string" },
        "averageHeight": { "type": "string" },
        "averageWeight": { "type": "string" },
        "distinguishingFeatures": { "type": "array", "items": { "type": "string" } },
        "abilities": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "habitat": { "type": "string" },
        "diet": { "type": "string" },
        "reproduction": { "type": "string" },
        "society": { "type": "string" },
        "language": { "type": "string" },
        "homeland": { "type": "string" },
        "subspecies": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
