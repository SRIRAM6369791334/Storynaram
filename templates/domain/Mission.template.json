{
  "template": "Mission",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseLifecycle", "BaseOwnership", "BaseReference", "BaseRelationship", "BaseTag", "BaseVisibility", "BaseValidation", "BaseAI", "BaseSearch", "BaseHistory", "BaseExtension"],
  "entityType": "mission",
  "description": "Reusable mission domain template. Defines a specific task or operation within a quest.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Mission-specific fields",
      "required": ["questId"],
      "properties": {
        "questId": { "type": "string" },
        "type": { "type": "string", "enum": ["investigation", "combat", "diplomacy", "stealth", "rescue", "retrieval", "escort", "assassination", "reconnaissance", "delivery", "other"] },
        "assignedBy": { "type": "string" },
        "assignedTo": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "objectives": { "type": "array", "items": { "type": "string" } },
        "successCriteria": { "type": "array", "items": { "type": "string" } },
        "failConditions": { "type": "array", "items": { "type": "string" } },
        "consequences": { "type": "object", "properties": { "success": { "type": "string" }, "failure": { "type": "string" } } },
        "rewards": { "type": "array", "items": { "type": "string" } },
        "difficulty": { "type": "string", "enum": ["trivial", "easy", "medium", "hard", "deadly"] },
        "timeLimit": { "type": "string" }
      }
    }
  }
}
