{
  "template": "Country",
  "version": "1.0.0",
  "extends": "BaseEntity",
  "inherits": ["BaseIdentifier", "BaseMetadata", "BaseAudit", "BaseVersion", "BaseStatus", "BaseOwnership", "BaseReference", "BaseRelationship", "BaseTag", "BaseVisibility", "BaseLocalization", "BaseAttachment", "BaseValidation", "BaseAI", "BaseSearch", "BaseHistory", "BaseExtension"],
  "entityType": "country",
  "description": "Reusable country domain template. Defines a sovereign nation or territory.",
  "required": ["identifier", "metadata", "audit"],
  "properties": {
    "entity": {
      "type": "object",
      "description": "Country-specific fields",
      "required": ["worldId"],
      "properties": {
        "worldId": { "type": "string" },
        "capital": { "type": "string" },
        "government": { "type": "string" },
        "ruler": { "type": "string" },
        "cities": { "type": "array", "items": { "type": "string" } },
        "regions": { "type": "array", "items": { "type": "string" } },
        "population": { "type": "integer", "minimum": 0 },
        "area": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "currency": { "type": "string" },
        "exports": { "type": "array", "items": { "type": "string" } },
        "imports": { "type": "array", "items": { "type": "string" } },
        "military": { "type": "string" },
        "allies": { "type": "array", "items": { "type": "string" } },
        "enemies": { "type": "array", "items": { "type": "string" } },
        "history": { "type": "string" }
      }
    }
  }
}
